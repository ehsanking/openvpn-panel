# Power VPN Panel — environment variables
#
# Copy to .env and fill in real values, or run `bash install.sh` which
# generates this file for you.

NODE_ENV=production
PORT=3000

# --- Admin credentials ------------------------------------------------------
# The username the admin signs in with.
ADMIN_USERNAME=

# bcrypt hash of the admin password. Generate one with:
#   node -e "console.log(require('bcryptjs').hashSync('YOUR_PASSWORD', 12))"
ADMIN_PASSWORD_HASH=

# --- Crypto -----------------------------------------------------------------
# Used by the JWT session signer (jose). Must be at least 32 characters.
# A safe value: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
JWT_SECRET=

# --- CORS -------------------------------------------------------------------
# Comma-separated list of origins allowed to talk to the API. Use '*' to
# allow any origin. The dedicated mobile / desktop app should be listed
# here when running it from a browser context (Capacitor / Expo Web).
ALLOWED_ORIGINS=http://localhost:3000

# --- Database ---------------------------------------------------------------
# Power VPN uses an embedded SQLite file at <project>/panel.sqlite by
# default. There is nothing to configure here.
