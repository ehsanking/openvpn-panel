# Database Configuration
MYSQL_HOST=localhost
MYSQL_USER=vpn_admin
MYSQL_PASSWORD=secure_password
MYSQL_DATABASE=vpn_panel
MYSQL_PORT=3306

# Admin Panel Access
ADMIN_USERNAME=admin

# Option 1 (development only): plaintext password – hashed automatically at startup
ADMIN_PASSWORD=admin

# Option 2 (recommended for production): pre-computed bcrypt hash
# Generate with: node -e "const b=require('bcryptjs'); console.log(b.hashSync('your_password',10));"
# ADMIN_PASSWORD_HASH=$2b$10$...

PORT=3000
